# Database
DATABASE_URL=postgresql+asyncpg://quanta:quanta@localhost:5432/quanta
DATABASE_URL_SYNC=postgresql://quanta:quanta@localhost:5432/quanta

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret
SESSION_EXPIRE_MINUTES=1440

# LLM (at least one provider required alongside Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AWS_BEDROCK_REGION=

# Market data vendor keys (leave blank if not subscribed)
# OpenBB ODP is a local library — no API key needed for it.
# These keys are for the underlying data vendors routed through OpenBB.
POLYGON_API_KEY=
DATABENTO_API_KEY=

# Broker (execution scope only — never exposed to agent or client)
# Paper trading: IBKR_PORT=4002 | Live trading: IBKR_PORT=4001
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1

# Notifications (all optional — leave blank to disable)
SES_REGION=
SES_FROM_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Environment
ENVIRONMENT=development
DEBUG=true
